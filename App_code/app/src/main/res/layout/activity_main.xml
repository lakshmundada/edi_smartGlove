<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Disconnected"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect to Glove" />

        <TextView
            android:id="@+id/tvSensorData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#EEEEEE"
            android:padding="10dp"
            android:text="Touch: - | X: - Z: -"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnCalibrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="1. Calibrate Gesture" />

        <EditText
            android:id="@+id/etLetter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Letter (e.g. A)"
            android:enabled="false"
            android:inputType="textCapCharacters"
            android:maxLength="1" />

        <EditText
            android:id="@+id/etText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Word (e.g. Apple)"
            android:enabled="false" />

        <Button
            android:id="@+id/btnAddGesture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="2. Save Gesture" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FF5252"
            android:enabled="false"
            android:text="Clear All Gestures"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>